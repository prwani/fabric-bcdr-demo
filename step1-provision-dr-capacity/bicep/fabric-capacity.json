{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "8337909032204477070"
    }
  },
  "parameters": {
    "capacityName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63,
      "metadata": {
        "description": "Name of the Microsoft Fabric capacity. Must start with a lowercase letter and contain only lowercase letters and numbers."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the Fabric capacity."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "F2",
      "allowedValues": [
        "F2",
        "F4",
        "F8",
        "F16",
        "F32",
        "F64",
        "F128",
        "F256",
        "F512",
        "F1024",
        "F2048"
      ],
      "metadata": {
        "description": "Fabric SKU for the DR capacity."
      }
    },
    "adminMembers": {
      "type": "array",
      "metadata": {
        "description": "Array of Entra user principal names that will administer the capacity."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Optional resource tags."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Fabric/capacities",
      "apiVersion": "2023-11-01",
      "name": "[parameters('capacityName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('skuName')]",
        "tier": "Fabric"
      },
      "properties": {
        "administration": {
          "members": "[parameters('adminMembers')]"
        }
      }
    }
  ],
  "outputs": {
    "capacityId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Fabric/capacities', parameters('capacityName'))]"
    },
    "capacityName": {
      "type": "string",
      "value": "[parameters('capacityName')]"
    },
    "capacityLocation": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Fabric/capacities', parameters('capacityName')), '2023-11-01', 'full').location]"
    },
    "capacitySku": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Fabric/capacities', parameters('capacityName')), '2023-11-01', 'full').sku.name]"
    }
  }
}